# ============================================
# 🍕 PIZZARIA BACKEND - ENVIRONMENT VARIABLES
# ============================================
# Este arquivo contém exemplos de variáveis de ambiente necessárias
# para rodar a aplicação. Copie este arquivo para .env e ajuste os valores.
#
# IMPORTANTE: 
# - NUNCA commite o arquivo .env com dados reais
# - Use valores diferentes em produção
# - Mantenha suas credenciais seguras
# ============================================

# --------------------------------------------
# 🗄️ DATABASE CONFIGURATION
# --------------------------------------------
# URL de conexão com o banco de dados PostgreSQL
# 
# Formato:
# postgresql://[usuario]:[senha]@[host]:[porta]/[database]?schema=public
#
# Exemplo local:
# postgresql://postgres:minhasenha@localhost:5432/pizzaria?schema=public
#
# Exemplo remoto (Railway, Supabase, etc):
# postgresql://user:password@host.com:5432/dbname?schema=public
#
# NOTA: Caracteres especiais na senha devem ser encodados (URL encoding)
# Exemplo: # vira %23, @ vira %40, etc.
# ============================================
DATABASE_URL="postgresql://postgres:suasenha@localhost:5432/pizzaria?schema=public"


# --------------------------------------------
# 🔐 JWT AUTHENTICATION
# --------------------------------------------
# Chave secreta usada para assinar e validar tokens JWT
# 
# SEGURANÇA:
# - Use uma string longa, aleatória e única
# - NUNCA use a mesma chave em desenvolvimento e produção
# - Troque periodicamente em produção
# - Nunca compartilhe ou versione esta chave
# 
# IMPORTANTE: Se você trocar esta chave, todos os tokens existentes
# se tornarão inválidos e os usuários precisarão fazer login novamente.
# ============================================
JWT_SECRET_KEY="93e5a981f8c8a2641fwdw617c5ccb550da0"
